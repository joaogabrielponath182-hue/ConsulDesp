{
  "entities": {
    "SubCategory": {
      "title": "SubCategory",
      "description": "Category or subcategory of income or expenses",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "defaultValue": { "type": "number" },
        "type": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "name", "defaultValue", "type", "userId"]
    },
    "Service": {
      "title": "Service",
      "description": "A service rendered with income items",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "client": { "type": "string" },
        "plate": { "type": "string" },
        "description": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "items": { "type": "array" },
        "totalValue": { "type": "number" },
        "date": { "type": "string" },
        "status": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "client", "plate", "description", "paymentMethod", "items", "totalValue", "date", "status", "userId"]
    },
    "Expense": {
      "title": "Expense",
      "description": "An office expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "value": { "type": "number" },
        "date": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "description", "category", "value", "date", "userId"]
    },
    "PersonalExpense": {
      "title": "PersonalExpense",
      "description": "A personal expense for financial analysis",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "value": { "type": "number" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "description", "value", "date", "category", "paymentMethod", "userId"]
    },
    "Backup": {
      "title": "Backup",
      "description": "A backup of user data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "timestamp": { "type": "number" },
        "services": { "type": "array" },
        "expenses": { "type": "array" },
        "subCategories": { "type": "array" },
        "userId": { "type": "string" }
      },
      "required": ["id", "date", "timestamp", "services", "expenses", "subCategories", "userId"]
    },
    "Client": {
      "title": "Client",
      "description": "A registered client",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "cpf": { "type": "string" },
        "phone": { "type": "string" },
        "company": { "type": "string" },
        "cnpj": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "name", "userId"]
    },
    "InternalUser": {
      "title": "InternalUser",
      "description": "An operator user with localized custom login",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "cpf": { "type": "string" },
        "phone": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" },
        "duration": { "type": "string" },
        "createdAt": { "type": "string" },
        "expiresAt": { "type": "string" },
        "currentSessionId": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "fullName", "username", "password", "userId"]
    }
  },
  "firestore": {
    "subcategories/{id}": {
      "schema": "SubCategory",
      "description": "User subcategories"
    },
    "services/{id}": {
      "schema": "Service",
      "description": "User services"
    },
    "expenses/{id}": {
      "schema": "Expense",
      "description": "User expenses"
    },
    "personal_expenses/{id}": {
      "schema": "PersonalExpense",
      "description": "User personal expenses"
    },
    "backups/{id}": {
      "schema": "Backup",
      "description": "User backups"
    },
    "clients/{id}": {
      "schema": "Client",
      "description": "User clients"
    },
    "internal_users/{id}": {
      "schema": "InternalUser",
      "description": "Internal custom users / operators"
    }
  }
}
