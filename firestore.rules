rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /subcategories/{id} {
      allow read, write: if true;
    }

    match /services/{id} {
      allow read, write: if true;
    }

    match /expenses/{id} {
      allow read, write: if true;
    }

    match /personal_expenses/{id} {
      allow read, write: if true;
    }

    match /backups/{id} {
      allow read, write: if true;
    }

    match /clients/{id} {
      allow read, write: if true;
    }

    match /internal_users/{id} {
      allow read, write: if true;
    }
  }
}
